{
  "name": "cat-svg-generator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "predev": "node scripts/check-node.mjs",
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:server\" \"npm run dev:web\"",
    "dev:local": "node scripts/check-node.mjs && node scripts/dev-mark-installed.mjs && node scripts/kill-stale-api.mjs --dev && npm run dev",
    "dev:win": "scripts\\dev-win.cmd",
    "check:api": "node scripts/check-api.mjs",
    "check:api-imports": "node scripts/check-api-imports.mjs",
    "check:login-paths": "node scripts/check-login-path-refs.mjs",
    "reset:admin": "node scripts/reset-admin-password.mjs",
    "backup:data": "node scripts/backup-data.mjs",
    "pack:deploy": "node scripts/pack-deploy.mjs",
    "restore:data": "node scripts/restore-data.mjs",
    "dev:web": "vite",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node server/index.js",
    "start:prod": "npm run build && node server/index.js",
    "install:cli": "node server/install-cli.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "make:favicon": "node scripts/make-favicon.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.5.0",
    "file-saver": "^2.0.5",
    "hono": "^4.7.11",
    "jose": "^6.0.11",
    "jszip": "^3.10.1",
    "opencc-js": "^1.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "fonteditor-core": "^2.6.3",
    "png-to-ico": "^2.1.8",
    "prettier": "^3.8.3",
    "sharp": "^0.34.2",
    "vite": "^6.0.3"
  }
}
