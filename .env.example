# =============================================================================
# CAT 证书系统 — 环境变量（复制为 .env 后修改）
# =============================================================================

# API 服务端口
PORT=3001

# 会话签名密钥（生产必须改为随机长串）
# 同时用于管理端 Cookie（cat_session）与公众页访客 Cookie（cat_visitor_session）
JWT_SECRET=请改为随机长字符串

# -----------------------------------------------------------------------------
# 管理端超级管理员（仅数据库为空时由 API 首次写入）
# -----------------------------------------------------------------------------
# 说明：
# - 第一个账号自动为 super_admin（超级管理员），侧栏可见「权限管理」
# - 数据库已有用户时，改此处不会自动改库内密码 → 请用 npm run reset:admin
# - 额外的普通管理员、公众页访客账号：登录后台 → 设置 → 权限管理（不在 .env 配置）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# 开发时前端地址（CORS，需与 Vite 地址一致）
CORS_ORIGIN=http://localhost:5173

# 生产部署时取消注释（HTTPS 下 Cookie 会带 Secure）
# NODE_ENV=production

# 也可直接运行 bash install.sh 或打开 /install.html 自动写入本文件

# -----------------------------------------------------------------------------
# 登录入口（无需写进 .env，仅供查阅）
# -----------------------------------------------------------------------------
# 管理端：/login.html 或 /admin.html → ADMIN_USERNAME / ADMIN_PASSWORD（或库内管理员）
# 公众页：/public-login.html → 后台「权限管理 → 访客账号」中创建的账号；浏览页为 /

# 前端字体（npm run build 时生效；默认七牛 CDN，无需打进 dist）
# VITE_FONT_URL=https://qiniu.uzzon.cn/fonts/SourceHanSansCN-Medium.ttf
# VITE_FONT_URL=/font/SourceHanSansCN-Medium.ttf
